[Unit]
Description=MagicBridgeV2 AI agent + macro runner
After=network-online.target kvmd.service
Wants=network-online.target

[Service]
Type=simple
Environment=MB_ROOT=/opt/magicbridge
Environment=MB_AGENT_PORT=8412
ExecStart=/usr/bin/python3 /opt/magicbridge/services/magicbridge-agent/app.py
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectHome=true

[Install]
WantedBy=multi-user.target
