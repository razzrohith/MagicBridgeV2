# ────────────────────────────────────────────────────────────────
#  MagicBridgeV2 — Branding configuration
#  Edit this ONE file to reskin the entire product. magic-install.sh
#  sources it and applies every value across OS, OLED, UI and mDNS.
# ────────────────────────────────────────────────────────────────

# Product identity
MB_PRODUCT_NAME="MagicBridge"
MB_PRODUCT_SHORT="MagicBridge"
MB_TAGLINE="Remote control, reimagined."
MB_VENDOR="Raj"
MB_VERSION="2.0.0-dev"

# Network identity (anonymity: a realistic per-unit hostname + MAC, no branded tells)
MB_HOSTNAME_REALISTIC="1"              # 1 = auto per-unit DESKTOP-XXXXXXX (not a tell); 0 = use MB_HOSTNAME below
MB_HOSTNAME="magicbridge"              # only used when MB_HOSTNAME_REALISTIC=0 (a branded tell — off by default)
MB_MAC_AUTOSPOOF="1"                   # 1 = realistic vendor MAC default (stable, persisted at the networkd layer)
MB_MDNS_ALIASES=""                     # branded .local aliases (e.g. magicbridge.local) — OFF by default (a tell); avahi still publishes <hostname>.local

# Web UI theme (cyan HUD — matches MagicBridge house style)
MB_COLOR_BG="#07131a"
MB_COLOR_ACCENT="#00e5ff"
MB_COLOR_ACCENT2="#b026ff"
MB_COLOR_TEXT="#e8f6fb"
MB_UI_TITLE="MagicBridge"
MB_UI_FAVICON="branding/assets/favicon.svg"
MB_UI_LOGO="branding/assets/logo.svg"

# OLED splash (128x32) — text shown on the front panel at boot
MB_OLED_LINE1="MagicBridge"
MB_OLED_LINE2="starting..."

# Feature flags (mirror V1 decisions)
MB_AGENT_ENABLED="false"               # AI Agent hidden until ready (V1 parity)
MB_STEALTH_ENABLED="true"
MB_DEFAULT_VIDEO="h264"                # WebRTC by default, native on V4 Mini

# Upstream (do not rebrand these — attribution)
MB_UPSTREAM="PiKVM / kvmd (GPLv3)"
